{
    "name": "resofire/discussion-participants",
    "description": "Shows avatars of users who have participated in a discussion.",
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "flarum/core": "^2.0.0-beta"
    },
    "autoload": {
        "psr-4": {
            "Resofire\\DiscussionParticipants\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Discussion Participants",
            "category": "discussion",
            "icon": {
                "name": "fas fa-users",
                "backgroundColor": "#3dd6c8",
                "color": "#fff"
            }
        }
    }
}
